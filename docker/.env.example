# Purpose: Facilitates containerization and deployment environments via .env.example.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Hephaestus Environment Variables
# Copy to .env and fill in real values before running.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── OpenMetadata ──────────────────────────────────────────────
OPENMETADATA_HOST=http://openmetadata-server
OPENMETADATA_PORT=8585
OPENMETADATA_JWT_TOKEN=your-jwt-token-here

# ── Qdrant Vector Store ──────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=hephaestus_embeddings

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=your-github-token-here
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=your-repo-name

# ── Sentinel Thresholds ──────────────────────────────────────
FGS_BLOCK_THRESHOLD=0.6
SEMANTIC_DRIFT_THRESHOLD=0.85
LAMBDA_DECAY=0.1
ALPHA_STRUCTURAL=0.7
BETA_VOLUME=0.3

# ── Embedding Model ──────────────────────────────────────────
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── MySQL (OpenMetadata backend) ─────────────────────────────
MYSQL_ROOT_PASSWORD=your-mysql-root-password-here
MYSQL_DATABASE=openmetadata_db
MYSQL_USER=openmetadata_user
MYSQL_PASSWORD=your-mysql-password-here

# ── API / Dashboard ──────────────────────────────────────────
DASHBOARD_ORIGIN=http://localhost:3000
REPO_PATH=/workspace/repo

